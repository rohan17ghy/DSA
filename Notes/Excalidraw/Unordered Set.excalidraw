			"fontSize": 20,
			"fontFamily": 5,
			"text": "Lookup still starts at the bucket index, but may walk the chain.\nWorst case O(n) if everything hashes to one bucket — implementations\ngrow & rehash to avoid that.",
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "Lookup still starts at the bucket index, but may walk the chain.\nWorst case O(n) if everything hashes to one bucket — implementations\ngrow & rehash to avoid that.",
			"lineHeight": 1.25,
			"baseline": 44,
			"index": "b1B",
			"autoResize": true,
			"hasTextLink": false,
			"rawText": "Lookup still starts at the bucket index, but may walk the chain.\nWorst case O(n) if everything hashes to one bucket — implementations\ngrow & rehash to avoid that."
		},
