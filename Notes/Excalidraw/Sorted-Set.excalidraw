			"updated": 1778898175260,
			"locked": false,
			"fontSize": 20,
			"fontFamily": 5,
			"text": "Typical implementation: balanced binary search tree (e.g. red–black, AVL) — O(log N) insert / delete / lookup\nwhen N is the number of keys. \n\nTraversal order matches sorted order.",
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "Typical implementation: balanced binary search tree (e.g. red–black, AVL) — O(log N) insert / delete / lookup\nwhen N is the number of keys. \n\nTraversal order matches sorted order.",
			"lineHeight": 1.25,
			"baseline": 15,
			"index": "b0R",
			"autoResize": true,
			"rawText": "Typical implementation: balanced binary search tree (e.g. red–black, AVL) — O(log N) insert / delete / lookup\nwhen N is the number of keys. \n\nTraversal order matches sorted order.",
			"hasTextLink": false,
			"link": null
		},
