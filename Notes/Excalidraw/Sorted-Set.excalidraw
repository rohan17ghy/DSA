			"fontSize": 20,
			"fontFamily": 5,
			"text": "Example: search 30\n40 → too big → left\n25 → too small → right\n30 → match\nPath length ≈ height.",
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "Example: search 30\n40 → too big → left\n25 → too small → right\n30 → match\nPath length ≈ height.",
