			"link": null,
			"locked": false,
			"fontSize": 20,
			"fontFamily": 5,
			"text": "Start at root.\n• key < node  → go left\n• key > node  → go right\n• equal       → found\nDescend at most tree height → O(log N) if balanced.",
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "Start at root.\n• key < node  → go left\n• key > node  → go right\n• equal       → found\nDescend at most tree height → O(log N) if balanced.",
			"lineHeight": 1.25,
			"baseline": 15,
			"index": "b0u",
			"autoResize": true,
			"rawText": "Start at root.\n• key < node  → go left\n• key > node  → go right\n• equal       → found\nDescend at most tree height → O(log N) if balanced.",
			"hasTextLink": false
		},
